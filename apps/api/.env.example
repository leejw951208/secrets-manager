# =============================================================
# API 환경 변수 예시
# =============================================================
# 이 파일을 복사해 환경별 실파일을 만든 뒤, 해당 환경 블록만 남긴다.
#   개발 → cp .env.example .env.development  → [개발 환경] 블록 사용, [운영 환경] 블록 삭제
#   운영 → cp .env.example .env.production   → [운영 환경] 블록의 주석(#)을 풀고 [개발 환경] 블록 삭제
# (컨테이너 배포 시에는 docker-compose 가 값을 직접 주입하므로 파일이 없어도 된다.)


# ─────────────────────────────────────────────────────────────
# [개발 환경]  → .env.development 에 그대로 사용
# ─────────────────────────────────────────────────────────────
# 로컬 docker compose 의 PostgreSQL(호스트 포트 5431)에 연결한다.
DATABASE_URL="postgresql://secrets:secrets@127.0.0.1:5431/secrets_manager?schema=public"
# 허용 웹 오리진(로컬).
CORS_ORIGIN=http://127.0.0.1:3000
VAULT_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# HOST/PORT 는 생략하면 127.0.0.1:4000 기본값을 쓴다(개발은 설정 불필요).


# ─────────────────────────────────────────────────────────────
# [운영 환경]  → .env.production 에서 아래 주석(#)을 풀어 사용
# ─────────────────────────────────────────────────────────────
# 1) 컨테이너 내부 postgres 서비스에 연결. 비밀번호 CHANGE_ME 는 반드시 변경한다.
# DATABASE_URL="postgresql://secrets:CHANGE_ME@postgres:5432/secrets_manager?schema=public"
# 2) 컨테이너에서는 외부 접근을 위해 0.0.0.0 으로 바인딩한다.
# HOST=0.0.0.0
# PORT=4000
# 3) 내 공개 도메인으로 변경한다.
# CORS_ORIGIN=https://myvault.example.com
# VAULT_ALLOWED_ORIGINS=https://myvault.example.com
