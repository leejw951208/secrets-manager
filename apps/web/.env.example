# =============================================================
# Web 환경 변수 예시
# =============================================================
# 이 파일을 복사해 환경별 실파일을 만든 뒤, 해당 환경 블록만 남긴다.
#   개발 → cp .env.example .env.development  → [개발 환경] 블록 사용, [운영 환경] 블록 삭제
#   운영 → cp .env.example .env.production   → [운영 환경] 블록의 주석(#)을 풀고 [개발 환경] 블록 삭제
# NEXT_PUBLIC_* 는 빌드 시점에 박힌다(next build 전에 설정).
# (docker 빌드 시에는 docker-compose 의 web.build.args 로 주입된다.)


# ─────────────────────────────────────────────────────────────
# [개발 환경]  → .env.development 에 그대로 사용
# ─────────────────────────────────────────────────────────────
# 브라우저가 호출할 백엔드 주소(로컬).
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4000


# ─────────────────────────────────────────────────────────────
# [운영 환경]  → .env.production 에서 아래 주석(#)을 풀어 사용
# ─────────────────────────────────────────────────────────────
# 내 공개 도메인으로 변경한다.
# NEXT_PUBLIC_API_BASE_URL=https://myvault.example.com
