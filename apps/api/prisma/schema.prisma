generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// WebAuthn passkey 자격증명 + PRF 로 래핑한 vault 키. 다중 기기 등록을 허용한다.
model WebauthnCredential {
  id           String    @id @default(cuid())
  credentialId Bytes     @unique // raw credential id
  publicKey    Bytes // COSE public key
  counter      BigInt    @default(0)
  transports   String[]
  deviceType   String?
  backedUp     Boolean   @default(false)
  prfSalt      Bytes // 이 자격증명의 PRF eval salt
  wrappedVkPrf Bytes // packed: iv||ct||tag
  nickname     String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  updatedAt    DateTime  @updatedAt
}

// 복구코드로 래핑한 vault 키(단일 행). 기기 분실 시 break-glass 용도이다.
model RecoveryWrap {
  id          String   @id @default("singleton")
  rcSalt      Bytes
  wrappedVkRc Bytes // packed: iv||ct||tag
  verifier    Bytes // SHA-256(복구코드 바이트). 복구 시점 상수시간 비교용. HKDF 키/평문 미보유.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 비밀번호를 묶는 최상위 단위. label 은 검색용 평문이고 icon 은 선택적이다.
model Site {
  id        String   @id @default(cuid())
  label     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  secrets    Secret[]

  @@index([label])
}

// 사이트 하위의 선택적 1계층 묶음. 자유 입력 라벨이다.
model Category {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  secrets Secret[]

  @@index([siteId])
  @@index([label])
}

// 라벨 평문 + AEAD 암호화된 비밀번호 본문 1건.
// categoryId 가 null 이면 사이트 직속이다. 카테고리 삭제 시 사이트 직속으로 남는다.
model Secret {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  label      String
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  kdfVersion Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([siteId])
  @@index([categoryId])
  @@index([label])
}
