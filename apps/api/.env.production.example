# 운영 환경 API 변수. 복사해서 `.env.production` 로 쓰거나 compose/배포 시 직접 주입한다.

# 컨테이너 내부 네트워크의 postgres 서비스. 비밀번호는 운영 전 반드시 변경한다.
DATABASE_URL="postgresql://secrets:CHANGE_ME@postgres:5432/secrets_manager?schema=public"

# 컨테이너에서는 외부 접근을 위해 0.0.0.0 으로 바인딩한다.
HOST=0.0.0.0
PORT=4000

# 내 공개 도메인으로 변경한다.
CORS_ORIGIN=https://myvault.example.com
VAULT_ALLOWED_ORIGINS=https://myvault.example.com
