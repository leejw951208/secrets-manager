# 개발 환경 API 변수. 복사해서 `.env.development` 로 사용한다.

# 로컬 PostgreSQL (docker compose 의 postgres, 호스트 포트 5431)
DATABASE_URL="postgresql://secrets:secrets@127.0.0.1:5431/secrets_manager?schema=public"

# 바인드/오리진은 미설정 시 로컬 기본값(127.0.0.1)이 적용된다.
# HOST=127.0.0.1
# PORT=4000
# CORS_ORIGIN=http://127.0.0.1:3000
# VAULT_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
