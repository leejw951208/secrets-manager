{
    "name": "@daeoebi/web",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev --hostname :: --port 3010",
        "build": "next build",
        "start": "next start --hostname :: --port 3000",
        "lint": "eslint \"{app,components,lib,tests}/**/*.{ts,tsx}\" \"*.{js,ts}\" --max-warnings 0",
        "typecheck": "tsc --noEmit",
        "test": "jest",
        "test:visual": "playwright test --config=playwright.visual.config.ts",
        "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
        "test:e2e": "playwright test --config=playwright.e2e.config.ts"
    },
    "dependencies": {
        "@simplewebauthn/browser": "^13.3.0",
        "axios": "^1.7.7",
        "lucide-react": "^0.460.0",
        "next": "^15.0.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.10.0",
        "@playwright/test": "^1.48.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/jest": "^29.5.13",
        "@types/node": "^22.7.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^9.11.0",
        "eslint-config-next": "^15.0.3",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.6.2"
    }
}
